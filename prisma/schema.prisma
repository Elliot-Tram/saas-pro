generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  company   String?
  phone     String?
  siret     String?
  address   String?
  city      String?
  postalCode String?

  // Professional info for certificates
  logo            String?  // base64 encoded logo image
  insuranceNumber String?  // N° police RC Pro
  insurerName     String?  // Nom de l'assureur
  qualification   String?  // Qualibat, CTM, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients      Client[]
  appointments Appointment[]
  invoices     Invoice[]
  quotes       Quote[]
  certificates Certificate[]
  contracts    Contract[]
}

model Client {
  id         String   @id @default(cuid())
  firstName  String
  lastName   String
  email      String?
  phone      String?
  address    String
  city       String?
  postalCode String?
  notes      String?

  // Sector for route planning
  sector      String?  // ex: "Annecy Nord", "Thônes", "Chamonix"

  // Chimney sweep specific fields
  chimneyType String?  // insert, foyer ouvert, poêle à bois, etc.
  fuelType    String?  // bois, granulés, fioul, gaz
  lastVisit   DateTime?
  nextReminder DateTime?

  userId    String
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  appointments Appointment[]
  invoices     Invoice[]
  quotes       Quote[]
  certificates Certificate[]
  contracts    Contract[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Appointment {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime
  status      String   @default("scheduled") // scheduled, completed, cancelled

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id      String @id @default(cuid())
  number  String @unique
  status  String @default("draft") // draft, sent, paid
  date    DateTime @default(now())
  dueDate DateTime?

  subtotal Float
  taxRate  Float  @default(20)
  tax      Float
  total    Float

  items InvoiceItem[]

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  total       Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Quote {
  id        String @id @default(cuid())
  number    String @unique
  status    String @default("draft") // draft, sent, accepted, rejected
  date      DateTime @default(now())
  validUntil DateTime?

  subtotal Float
  taxRate  Float  @default(20)
  tax      Float
  total    Float

  items QuoteItem[]

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuoteItem {
  id          String @id @default(cuid())
  description String
  quantity    Float  @default(1)
  unitPrice   Float
  total       Float

  quoteId String
  quote   Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Certificate {
  id              String   @id @default(cuid())
  number          String   @unique
  date            DateTime @default(now())

  // Client context
  clientQuality   String   @default("proprietaire") // proprietaire, locataire, syndic

  // Chimney details
  chimneyType     String   // insert, foyer_ouvert, poele_bois, poele_granules, chaudiere
  chimneyLocation String?  // ex: Salon RDC, Chambre 1er étage
  fuelType        String?  // bois, granules, fioul, gaz
  applianceBrand  String?  // Marque de l'appareil
  applianceModel  String?  // Modèle

  // Intervention
  method          String   @default("mecanique_haut") // mecanique_haut, mecanique_bas, chimique, mixte
  conduitType     String?  // maçonné, tubé inox, tubé flexible
  conduitDiameter String?  // ex: 150mm, 180mm
  conduitLength   String?  // ex: 8m

  // Assessment
  condition       String   // bon_etat, a_surveiller, dangereux
  vacuumTest      Boolean  @default(true)
  anomalies       Json?    // JSON checklist of anomalies found
  observations    String?
  recommendations String?

  // Periodicity & follow-up
  periodicity     String   @default("annuel") // annuel, semestriel
  nextVisit       DateTime?

  // Signatures (base64 PNG)
  proSignature    String?  // Professional's signature
  clientSignature String?  // Client's signature

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contract {
  id          String   @id @default(cuid())
  number      String   @unique
  status      String   @default("active") // active, expired, cancelled
  startDate   DateTime
  endDate     DateTime
  amount      Float    // Annual price
  description String?
  autoRenew   Boolean  @default(true)

  visits      Int      @default(1) // Number of visits per year included
  visitsDone  Int      @default(0) // Number completed this period

  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
